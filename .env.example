# OpenRouter API key (free tier — get yours at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of WhatsApp group JIDs to respond in
# Find your group JID: add the bot, send a message, check the logs
GROUP_WHITELIST=120363000000000000@g.us,120363111111111111@g.us

# Bot trigger — only responds when message starts with this prefix (optional)
# Leave empty to respond to ALL messages in whitelisted groups
BOT_PREFIX=!claw

# Response rate — probability of responding to a message (0.0 to 1.0)
# Default 0.1 = responds to ~10% of messages randomly
# Replies and @mentions always get a response (bypass)
# Set to 1.0 to always respond
RESPONSE_RATE=0.1

# Log level (silent, fatal, error, warn, info, debug, trace)
LOG_LEVEL=info

# ─── Optional: Premium providers (API key or OAuth) ──────────
# These unlock better models. Priority: env key > OAuth > OpenRouter.

# Anthropic API key (alternative to OAuth login)
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI API key (alternative to OAuth login)
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o-mini

# Force a specific provider as primary
# PREFERRED_PROVIDER=anthropic

# Custom path to pi-ai auth.json (default: ./auth.json)
# Created by: npx @mariozechner/pi-ai login anthropic (or openai-codex)
# PI_AI_AUTH_PATH=/path/to/auth.json
